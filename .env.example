# =====================================================
# EkiTili — переменные окружения
# =====================================================
# Локально: скопируй в .env и заполни.
# На Vercel: задай через Project Settings → Environment Variables.

# -----------------------------------------------------
# Supabase PostgreSQL
# -----------------------------------------------------
# ЛОКАЛЬНО (long-lived node сервер) — используй Session Pooler, порт 5432:
#   PGHOST=aws-0-<region>.pooler.supabase.com
#   PGPORT=5432
#
# НА VERCEL (serverless, короткие инвокации) — используй Transaction Pooler, порт 6543:
#   PGHOST=aws-0-<region>.pooler.supabase.com
#   PGPORT=6543
#
# В обоих случаях PGUSER формата: postgres.<project_ref>
PGHOST=aws-0-eu-central-1.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.YOUR_PROJECT_REF
PGPASSWORD=your_password_here
PGDATABASE=postgres
PGSSLMODE=require

# -----------------------------------------------------
# HTTP сервер (только локально — Vercel игнорирует)
# -----------------------------------------------------
PORT=3000

# -----------------------------------------------------
# Security
# -----------------------------------------------------
# Подписывает session-cookie. ОБЯЗАТЕЛЬНО в production/Vercel — без него
# приложение падает при старте. Без него в dev — генерируется одноразовый.
# Генерация: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Список разрешённых CORS origins через запятую.
# В dev также пускаются http(s)://localhost, 127.0.0.1 и частные IPv4-адреса.
# На Vercel обязательно задай свой домен:
# ALLOWED_ORIGINS=https://ekitili.vercel.app,https://ekitili.example.com

# NODE_ENV=production автоматически выставляется Vercel'ем — задавать вручную не надо.
