# Supabase PostgreSQL connection
# Get these from: Supabase Dashboard -> Project Settings -> Database
PGHOST=db.YOUR_PROJECT_REF.supabase.co
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=postgres
PGSSLMODE=require

# Server
PORT=3000

# Security
# Secret для подписи session-cookie. ОБЯЗАТЕЛЬНО задать в продакшене —
# иначе при каждом рестарте сервер генерирует одноразовый и все сессии инвалидируются.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Список разрешённых CORS origins через запятую.
# По умолчанию пускаются http(s)://localhost, 127.0.0.1 и частные IPv4-адреса.
# ALLOWED_ORIGINS=https://ekitili.example.com

# Установить в production когда сервер за TLS — включает Secure флаг на cookie.
# NODE_ENV=production
